#: data/app.drey.Vocalis.desktop.in.in:4
#: data/app.drey.Vocalis.metainfo.xml.in.in:5 data/ui/window.ui:10
msgid "Vocalis"
msgstr "वोकलिस"

#: data/app.drey.Vocalis.desktop.in.in:5
msgid "Record sound via the microphone and play it back"
msgstr "माइक्रोफोन के माध्यम से ध्वनि रिकॉर्ड करें और उसे वापस सुनें"

#. Translators: Search terms to find this application. Do NOT translate or localize the semicolons! The list MUST also end with a semicolon!
#: data/app.drey.Vocalis.desktop.in.in:10
msgid "Audio;Application;Record;Sound Recorder;"
msgstr "Audio;Application;Record;ऑडियो;अनुप्रयोग;रिकॉर्ड;साउंड रिकॉर्डर;"

#: data/app.drey.Vocalis.metainfo.xml.in.in:6
msgid "Take notes with your voice"
msgstr "अपनी आवाज़ से नोट्स लें"

#: data/app.drey.Vocalis.metainfo.xml.in.in:10
msgid ""
"Vocalis provides a simple and modern interface that provides a straight-"
"forward way to record and play voice memos."
msgstr ""
"वोकलिस एक सरल और आधुनिक इंटरफ़ेस प्रदान करता है जो वॉयस मेमो को रिकॉर्ड करने और चलाने "
"का सीधा तरीका प्रदान करता है।"

#: data/app.drey.Vocalis.metainfo.xml.in.in:14
msgid ""
"Vocalis automatically handles the saving process so that you do not need to "
"worry about accidentally discarding the previous recording."
msgstr ""
"वोकलिस स्वचालित रूप से सहेजने की प्रक्रिया को संभालता है ताकि आपको पिछली रिकॉर्डिंग को "
"गलती से त्यागने के बारे में चिंता करने की आवश्यकता न हो।"

#: data/app.drey.Vocalis.metainfo.xml.in.in:18
msgid "Supported audio formats:"
msgstr "समर्थित ऑडियो प्रारूप:"

#: data/app.drey.Vocalis.metainfo.xml.in.in:20
msgid "Ogg Vorbis, Opus, FLAC, MP3 and MOV"
msgstr "Ogg Vorbis, Opus, FLAC, MP3 और MOV"

#: data/app.drey.Vocalis.metainfo.xml.in.in:40
msgid "Christopher Davis"
msgstr "क्रिस्टोफर डेविस"

#: data/app.drey.Vocalis.gschema.xml.in:15
msgid "Window size"
msgstr "विंडो का आकार"

#: data/app.drey.Vocalis.gschema.xml.in:16
msgid "Window size (width and height)."
msgstr "विंडो का आकार (चौड़ाई और ऊँचाई)"

#: data/app.drey.Vocalis.gschema.xml.in:20
msgid "Window position"
msgstr "विंडो का स्थान"

#: data/app.drey.Vocalis.gschema.xml.in:21
msgid "Window position (x and y)."
msgstr "विंडो का स्थान (x और y)"

# Exact translation is not done, as it looks weird. Instead, this translation describes what the dconf setting would actually do (this string is displayed in apps like dconf-editor)
#: data/app.drey.Vocalis.gschema.xml.in:25
msgid "Maps media types to audio encoder preset names."
msgstr "मीडिया प्रकारों को ऑडियो एन्कोडर पूर्व निर्धारित नामों पर मैप करता है।"

# Exact translation is not done, as it looks weird. Instead, this translation describes what the dconf setting would actually do (this string is displayed in apps like dconf-editor)
#: data/app.drey.Vocalis.gschema.xml.in:26
msgid ""
"Maps media types to audio encoder preset names. If there is no mapping set, "
"the default encoder settings will be used."
msgstr ""
"यह तय करता है कि कौन-सा ऑडियो प्रारूप प्रयोग किया जाएगा। अगर कोई प्रारूप सेट नहीं "
"किया जाए, तो स्वत: इनकॉडर की सेटिंग्स का प्रयोग किया जाएगा।"

# Exact translation is not done, as it looks weird. Instead, this translation describes what the dconf setting would actually do (this string is displayed in apps like dconf-editor)
#: data/app.drey.Vocalis.gschema.xml.in:30
msgid "Available channels"
msgstr "चैनल"

# Exact translation is not done, as it looks weird. Instead, this translation describes what the dconf setting would actually do (this string is displayed in apps like dconf-editor)
#: data/app.drey.Vocalis.gschema.xml.in:31
msgid ""
"Maps available channels. If there is not no mapping set, stereo channel will "
"be used by default."
msgstr ""
"यह तय करता है कि कौन-सा चैनल प्रयोग किया जाएगा। अगर कोई चैनल सेट नहीं किया जाए, तो "
"स्वत: stereo (द्वैध) चैनल का प्रयोग किया जाएगा।"

