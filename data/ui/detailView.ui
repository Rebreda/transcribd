<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <template class="Gjs_RecordingDetailView" parent="AdwToolbarView">
    <child type="top">
      <object class="AdwHeaderBar" id="headerBar">
        <property name="show-back-button">False</property>
        <property name="title-widget">
          <object class="GtkEditableLabel" id="titleLabel">
            <property name="halign">center</property>
            <property name="hexpand">True</property>
          </object>
        </property>
        <child type="end">
          <object class="GtkMenuButton" id="actionsMenuBtn">
            <property name="icon_name">view-more-symbolic</property>
            <property name="tooltip_text" translatable="yes">More Actions</property>
            <style>
              <class name="image-button"/>
            </style>
          </object>
        </child>
      </object>
    </child>
    <property name="content">
      <object class="GtkScrolledWindow">
        <property name="hscrollbar_policy">never</property>
        <property name="vexpand">True</property>
        <property name="child">
          <object class="GtkViewport">
            <property name="scroll_to_focus">True</property>
            <property name="child">
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <property name="margin_start">18</property>
                <property name="margin_end">18</property>
                <property name="margin_top">16</property>
                <property name="margin_bottom">24</property>
                <property name="spacing">18</property>

                <!-- Metadata row: date, duration, category -->
                <child>
                  <object class="GtkBox">
                    <property name="spacing">12</property>
                    <property name="halign">start</property>
                    <child>
                      <object class="GtkLabel" id="dateLabel">
                        <property name="xalign">0</property>
                        <style>
                          <class name="dim-label"/>
                          <class name="caption"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="durationLabel">
                        <property name="use_markup">True</property>
                        <property name="xalign">0</property>
                        <style>
                          <class name="dim-label"/>
                          <class name="caption"/>
                          <class name="numeric"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkSeparator">
                        <property name="orientation">vertical</property>
                        <property name="margin_top">4</property>
                        <property name="margin_bottom">4</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkEntry" id="categoryEntry">
                        <property name="placeholder-text" translatable="yes">Add category…</property>
                        <property name="max_width_chars">20</property>
                        <property name="has_frame">False</property>
                        <style>
                          <class name="caption"/>
                        </style>
                      </object>
                    </child>
                  </object>
                </child>

                <!-- Waveform container -->
                <child>
                  <object class="GtkBox" id="waveformContainer">
                    <property name="height_request">80</property>
                    <property name="hexpand">True</property>
                  </object>
                </child>

                <!-- Seek bar row -->
                <child>
                  <object class="GtkBox">
                    <property name="spacing">8</property>
                    <property name="hexpand">True</property>
                    <child>
                      <object class="GtkLabel" id="positionLabel">
                        <property name="use_markup">True</property>
                        <property name="label">00 ∶ 00 ∶ 00 . <small>0</small></property>
                        <style>
                          <class name="numeric"/>
                          <class name="caption"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkScale" id="seekBar">
                        <property name="hexpand">True</property>
                        <property name="draw_value">False</property>
                        <property name="adjustment">
                          <object class="GtkAdjustment">
                            <property name="lower">0</property>
                            <property name="upper">1</property>
                            <property name="step_increment">0.01</property>
                          </object>
                        </property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="durationTimeLabel">
                        <property name="use_markup">True</property>
                        <property name="label">00 ∶ 00 ∶ 00 . <small>0</small></property>
                        <style>
                          <class name="numeric"/>
                          <class name="caption"/>
                          <class name="dim-label"/>
                        </style>
                      </object>
                    </child>
                  </object>
                </child>

                <!-- Playback controls -->
                <child>
                  <object class="GtkBox">
                    <property name="spacing">12</property>
                    <property name="halign">center</property>
                    <child>
                      <object class="GtkButton" id="seekBackBtn">
                        <property name="icon_name">media-seek-backward-symbolic</property>
                        <property name="tooltip_text" translatable="yes">Skip Back 10s</property>
                        <style>
                          <class name="circular"/>
                          <class name="flat"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkStack" id="playPauseStack">
                        <property name="transition_type">crossfade</property>
                        <child>
                          <object class="GtkStackPage">
                            <property name="name">play</property>
                            <property name="child">
                              <object class="GtkButton" id="playBtn">
                                <property name="icon_name">media-playback-start-symbolic</property>
                                <property name="tooltip_text" translatable="yes">Play</property>
                                <style>
                                  <class name="circular"/>
                                  <class name="suggested-action"/>
                                </style>
                              </object>
                            </property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkStackPage">
                            <property name="name">pause</property>
                            <property name="child">
                              <object class="GtkButton" id="pauseBtn">
                                <property name="icon_name">media-playback-pause-symbolic</property>
                                <property name="tooltip_text" translatable="yes">Pause</property>
                                <style>
                                  <class name="circular"/>
                                  <class name="suggested-action"/>
                                </style>
                              </object>
                            </property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="seekFwdBtn">
                        <property name="icon_name">media-seek-forward-symbolic</property>
                        <property name="tooltip_text" translatable="yes">Skip Forward 10s</property>
                        <style>
                          <class name="circular"/>
                          <class name="flat"/>
                        </style>
                      </object>
                    </child>
                  </object>
                </child>

                <!-- Transcription section -->
                <child>
                  <object class="GtkStack" id="transcriptionStack">
                    <child>
                      <object class="GtkStackPage">
                        <property name="name">empty</property>
                        <property name="child">
                          <object class="GtkBox">
                            <property name="orientation">vertical</property>
                            <property name="spacing">12</property>
                            <property name="halign">center</property>
                            <property name="margin_top">12</property>
                            <property name="margin_bottom">12</property>
                            <child>
                              <object class="GtkLabel">
                                <property name="label" translatable="yes">No transcription available</property>
                                <style>
                                  <class name="dim-label"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="transcribeBtn">
                                <property name="label" translatable="yes">Transcribe Recording</property>
                                <style>
                                  <class name="pill"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkStackPage">
                        <property name="name">text</property>
                        <property name="child">
                          <object class="GtkBox">
                            <property name="orientation">vertical</property>
                            <property name="spacing">8</property>

                            <!-- Transcript header -->
                            <child>
                              <object class="GtkBox">
                                <property name="spacing">6</property>
                                <child>
                                  <object class="GtkImage">
                                    <property name="icon_name">microphone-sensitivity-high-symbolic</property>
                                    <property name="pixel_size">14</property>
                                    <style>
                                      <class name="dim-label"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="label" translatable="yes">Transcript</property>
                                    <property name="hexpand">True</property>
                                    <property name="xalign">0</property>
                                    <style>
                                      <class name="heading"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkButton" id="injectBtn">
                                    <property name="icon_name">edit-paste-symbolic</property>
                                    <property name="tooltip_text" translatable="yes">Inject at Cursor</property>
                                    <style>
                                      <class name="flat"/>
                                      <class name="circular"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkButton" id="retranscribeBtn">
                                    <property name="icon_name">view-refresh-symbolic</property>
                                    <property name="tooltip_text" translatable="yes">Re-transcribe</property>
                                    <style>
                                      <class name="flat"/>
                                      <class name="circular"/>
                                    </style>
                                  </object>
                                </child>
                              </object>
                            </child>

                            <!-- Transcript text view -->
                            <child>
                              <object class="GtkScrolledWindow">
                                <property name="hscrollbar_policy">never</property>
                                <property name="min_content_height">80</property>
                                <property name="max_content_height">400</property>
                                <property name="propagate_natural_height">True</property>
                                <child>
                                  <object class="GtkTextView" id="transcriptionView">
                                    <property name="wrap_mode">word-char</property>
                                    <property name="editable">False</property>
                                    <property name="cursor_visible">False</property>
                                    <property name="top_margin">8</property>
                                    <property name="bottom_margin">8</property>
                                    <property name="left_margin">12</property>
                                    <property name="right_margin">12</property>
                                  </object>
                                </child>
                              </object>
                            </child>

                          </object>
                        </property>
                      </object>
                    </child>
                  </object>
                </child>

              </object>
            </property>
          </object>
        </property>
      </object>
    </property>
  </template>
</interface>
