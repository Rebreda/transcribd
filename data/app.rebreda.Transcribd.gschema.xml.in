<schemalist>
  <enum id="@app-id@.AudioProfile">
    <value nick='vorbis' value='0'/>
    <value nick='opus' value='1'/>
    <value nick='flac' value='2'/>
    <value nick='mp3' value='3'/>
  </enum>
  <enum id="@app-id@.AudioChannel">
    <value nick='stereo' value='0'/>
    <value nick='mono' value='1'/>
  </enum>
  <schema id="@app-id@" path="/app/rebreda/Transcribd/" gettext-domain="@gettext-package@">
    <key name="window-size" type="ai">
      <default>[780, 480]</default>
      <summary>Window size</summary>
      <description>Window size (width and height).</description>
    </key>
    <key name="window-position" type="ai">
      <default>[]</default>
      <summary>Window position</summary>
      <description>Window position (x and y).</description>
    </key>
    <key name="audio-profile" enum="@app-id@.AudioProfile">
      <default>'opus'</default>
      <summary>Maps media types to audio encoder preset names.</summary>
      <description>Maps media types to audio encoder preset names. If there is no mapping set, the default encoder settings will be used.</description>
    </key>
    <key name="audio-channel" enum="@app-id@.AudioChannel">
      <default>'stereo'</default>
      <summary>Available channels</summary>
      <description>Maps available channels. If there is not no mapping set, stereo channel will be used by default.</description>
    </key>
    <key name="transcription-enabled" type="b">
      <default>false</default>
      <summary>Enable transcription</summary>
      <description>Whether to enable real-time audio transcription.</description>
    </key>
    <key name="transcription-server-url" type="s">
      <default>'http://localhost:8080/api/v1'</default>
      <summary>Transcription server URL</summary>
      <description>Base URL of the OpenAI-compatible transcription server.</description>
    </key>
    <key name="transcription-model" type="s">
      <default>'Whisper-Tiny'</default>
      <summary>Transcription model</summary>
      <description>Whisper model name to use for transcription.</description>
    </key>
    <key name="transcription-api-key" type="s">
      <default>'lemonade'</default>
      <summary>Transcription API key</summary>
      <description>API key for the transcription server.</description>
    </key>
    <key name="transcription-inject-text" type="b">
      <default>false</default>
      <summary>Inject transcribed text at cursor</summary>
      <description>Whether to inject the transcription at the cursor after dictation stops.</description>
    </key>
  </schema>
</schemalist>



